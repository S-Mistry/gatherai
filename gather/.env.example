# Runtime app URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only app secrets
SUPABASE_SECRET_KEY=

# Setup-only Supabase operator token for bootstrap automation
SUPABASE_ACCESS_TOKEN=

# Consultant auth mode
CONSULTANT_AUTH_MODE=supabase_oauth
SUPABASE_OAUTH_PROVIDER=google

# Optional Google OAuth provider bootstrap values
# Used by `npm --prefix gather run supabase:bootstrap` to enable Google in Supabase Auth.
# Never expose these in the browser bundle.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# AI and observability
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE_NAME=alloy
OPENAI_SESSION_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_PROJECT_SYNTHESIS_MODEL=gpt-5.4
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=gatherai-mvp

# Local application secrets
RECOVERY_TOKEN_SECRET=change-me
CRON_SECRET=change-me
